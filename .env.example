# DEEPSEEK_API_KEY: API key for DeepSeek API.
DEEPSEEK_API_KEY=

# GEMINI_API_KEY: API key for Google Gemini API (Fallback).
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# JWT_SECRET: Secret key for signing JWT tokens.
JWT_SECRET="your-secret-key-here"

# Database Configuration (MySQL/MariaDB)
# If these are provided, the app will use MySQL instead of SQLite.
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=3306
